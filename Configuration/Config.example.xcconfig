// Garajım — Configuration Template
// Bu dosyayı proje köküne Config.xcconfig olarak kopyalayıp
// gerçek değerleri yazın. Config.xcconfig gitignore'dadır —
// production secret'ları asla commit etmeyin.
//
// Xcode'da Config.xcconfig'in build configuration'a atanmış olması gerekir:
//   Target: Ruhsatim → Info → Configurations
//   Debug: Config.xcconfig
//   Release: Config.xcconfig
//
// Key'ler INFOPLIST_KEY_ prefix'i ile tanımlanır.
// GENERATE_INFOPLIST_FILE = YES ile Info.plist otomatik oluşturulduğu için
// bu prefix Xcode'a "bu değeri Info.plist'e ekle" talimatını verir.
// Çalışma zamanında Bundle.main.object(forInfoDictionaryKey: "SUPABASE_URL")
// ile okunur (INFOPLIST_KEY_ prefix'i Info.plist'te görünmez).

// Supabase proje URL'si (https://YOUR-PROJECT.supabase.co)
INFOPLIST_KEY_SUPABASE_URL = https://YOUR-PROJECT.supabase.co

// Supabase anonymous key (public, RLS ile korunur)
INFOPLIST_KEY_SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_PUBLIC_KEY
